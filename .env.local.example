# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Apple Wallet
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_PASS_TYPE_ID=pass.de.myvi.visitenkarte
PASS_PHRASE=dein-zertifikat-passwort

# Zertifikate als Base64 (für Vercel)
# Lokal: Leer lassen – werden direkt aus /certs/ gelesen
CERT_SIGNER_CERT=
CERT_SIGNER_KEY=
CERT_WWDR=

# Optional: Basis-URL für QR-Code
NEXT_PUBLIC_BASE_URL=https://wallet.myvi.de
